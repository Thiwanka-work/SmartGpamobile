{
  "expo": {
    "name": "SmartGPA",
    "slug": "SmartGpaCalApp",
    "scheme": "smartgpacalapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "jsEngine": "hermes",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121226"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thiwana.smartgpa"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121226",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.thiwana.smartgpa",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e5c8b7f0-3e59-4b93-9a79-dab000c55879"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
